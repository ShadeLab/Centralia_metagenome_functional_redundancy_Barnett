#!/bin/bash

########### Resource request ############

#SBATCH --job-name=kofamscan
#SBATCH --time=72:00:00
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=10
#SBATCH --mem=10G
#SBATCH -A shade-cole-bonito
#SBATCH --output=kofamscan.%A_%a.out
#SBATCH --array=1-69

########### Command lines ###########

module load Conda/3
conda activate genome_annotation

config=full_sample_config.txt

pfx=$(awk -v ArrayTaskID=$SLURM_ARRAY_TASK_ID '$1==ArrayTaskID {print $2}' $config)

echo "Begining kofamscan annotations"
echo ${pfx}
date

~/notebooks/Centralia_metagenome/annotation/kofam_scan-1.3.0/exec_annotation \
	--format mapper \
	--profile /mnt/research/ShadeLab/Barnett/databases/kofam/profiles \
	--cpu 10 \
	--ko-list /mnt/research/ShadeLab/Barnett/databases/kofam/ko_list \
	--tmp-dir /mnt/research/ShadeLab/Barnett/Centralia_metagenome/annotations/KEGG_annotations/tmp_dirs/${pfx}.temp \
	-o /mnt/research/ShadeLab/Barnett/Centralia_metagenome/annotations/KEGG_annotations/${pfx}.kegg.map \
	/mnt/research/ShadeLab/Barnett/Centralia_metagenome/annotations/metagenome_prokka_output/${pfx}/${pfx}.prokka.faa
echo "Done!"
date

conda deactivate
